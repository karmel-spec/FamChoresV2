# Where the SQLite database and uploaded photos are stored.
# On Railway: create a Volume, mount it at /data, and set DATA_DIR=/data
# so your data persists across deploys. Leave unset locally (defaults to ./data).
DATA_DIR=/data

# Secret used to sign the parent-admin session cookie. Set this to any long random
# string in production. The default parent passcode is 1234 — change it in
# Parent admin -> Settings after first login.
AUTH_SECRET=change-me-to-a-long-random-string
